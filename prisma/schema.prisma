generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  uploads   Upload[]
}

model Upload {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  score     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
